	mapping inMM1::IotSystem::unionIsRequestedResource2Expression():TimeModel::CCSLModel::ClockExpressionAndRelation::Expression
	{
		init{

	

		

		var sources : Sequence(Resource) := self.ownedResource->asSequence();
		var lastExpr : TimeModel::CCSLModel::ClockExpressionAndRelation::Expression :=null;
